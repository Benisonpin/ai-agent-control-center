# === 場景切換 API ===
@app.post("/api/scene/switch")
async def switch_scene(request: SceneRequest):
    """切換場景模式"""
    valid_scenes = ["indoor_inspection", "outdoor_patrol", "low_light", "hdr_capture"]
    
    if request.scene_name not in valid_scenes:
        return {
            "success": False,
            "error": f"無效場景: {request.scene_name}",
            "valid_scenes": valid_scenes,
            "suggestion": "請使用有效的場景名稱"
        }
    
    # 場景特定配置
    scene_configs = {
        "indoor_inspection": {
            "brightness": 128, "contrast": 1.2, "saturation": 1.0,
            "auto_focus": True, "stabilization": "high"
        },
        "outdoor_patrol": {
            "brightness": 140, "contrast": 1.5, "saturation": 1.1,
            "auto_focus": True, "stabilization": "medium", "hdr": True
        },
        "low_light": {
            "brightness": 100, "contrast": 0.8, "saturation": 0.9,
            "auto_focus": "infinity", "noise_reduction": "aggressive"
        },
        "hdr_capture": {
            "brightness": 130, "contrast": 1.3, "saturation": 1.2,
            "bracketing": True, "alignment": "precise"
        }
    }
    
    return {
        "success": True,
        "message": f"已成功切換到 {request.scene_name} 模式",
        "scene_name": request.scene_name,
        "previous_scene": "auto_detect",
        "applied_settings": scene_configs[request.scene_name],
        "optimization_time_ms": 150,
        "auto_calibration_applied": True,
        "timestamp": datetime.now().isoformat()
    }

@app.get("/api/scene/detect")
async def detect_scene():
    """自動場景檢測"""
    import random
    
    # 模擬場景檢測結果
    scenes = ["outdoor_patrol", "indoor_inspection", "low_light", "hdr_capture"]
    confidences = [0.87, 0.23, 0.15, 0.31]
    
    detected_scenes = [
        {
            "scene": scene,
            "confidence": conf,
            "lighting_condition": ["bright", "artificial", "dim", "mixed"][i],
            "motion_detected": random.choice([True, False]),
            "recommended": i == 0
        }
        for i, (scene, conf) in enumerate(zip(scenes, confidences))
    ]
    
    return {
        "success": True,
        "detected_scenes": detected_scenes,
        "primary_recommendation": detected_scenes[0]["scene"],
        "detection_algorithm": "CNN_SceneNet_v2.1",
        "analysis_metrics": {
            "lighting_analysis": "completed",
            "object_detection": "6 objects found",
            "motion_analysis": "stable",
            "color_temperature": "5200K"
        },
        "detection_time_ms": 45,
        "confidence_threshold": 0.75,
        "timestamp": datetime.now().isoformat()
    }


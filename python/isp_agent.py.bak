# === ISP 配置管理 ===
@app.post("/api/isp/config")
async def update_isp_config(config: ISPConfig):
    """更新 ISP 配置參數"""
    try:
        # 處理配置更新
        config_summary = {
            "exposure_mode": config.exposure.get("mode", "auto") if config.exposure else "auto",
            "white_balance_mode": config.white_balance.get("mode", "auto") if config.white_balance else "auto", 
            "noise_reduction_strength": config.noise_reduction.get("strength", "medium") if config.noise_reduction else "medium",
            "hdr_enabled": config.hdr.get("enabled", False) if config.hdr else False,
            "scene_mode": config.scene or "auto_detect"
        }
        
        # 估算效能影響
        performance_impact = {
            "fps": "32.5" if not config_summary["hdr_enabled"] else "30.0",
            "latency_ms": "28" if config_summary["noise_reduction_strength"] != "high" else "35",
            "power_consumption_w": "3.5",
            "processing_load": "normal"
        }
        
        return {
            "success": True,
            "message": "ISP 配置已成功更新",
            "applied_config": config_summary,
            "performance_estimate": performance_impact,
            "optimization_applied": True,
            "timestamp": datetime.now().isoformat()
        }
    except Exception as e:
        raise HTTPException(status_code=500, detail=f"配置更新失敗: {str(e)}")


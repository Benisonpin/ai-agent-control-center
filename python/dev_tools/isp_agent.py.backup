        "total_commands": len(commands)
    }

# 6. 快速系統診斷
@app.get("/api/cloud/diagnosis")
async def system_diagnosis():
    """快速系統診斷"""
    diagnosis = {
        "timestamp": datetime.now().isoformat(),
        "system_info": {},
        "file_status": {},
        "process_status": {},
        "recommendations": []
    }
    
    # 檢查關鍵檔案
    key_files = [
        "~/isp_ai_agent/src/rtos/main.c",
        "~/isp_ai_agent/src/hal/ums_hal_integration.h", 
        "~/ai-agent-dev/isp_agent.py",
        "~/isp_pipeline_verification/tb/waveforms/ums_test.vcd"
    ]
    
    for file_path in key_files:
        expanded_path = os.path.expanduser(file_path)
        diagnosis["file_status"][file_path] = os.path.exists(expanded_path)
        
        if not os.path.exists(expanded_path):
            diagnosis["recommendations"].append(f"檔案缺失: {file_path}")
    
    # 檢查目錄結構
    key_dirs = [
        "~/isp_ai_agent",
        "~/ai-agent-dev", 
        "~/isp_pipeline_verification"
    ]
    
    for dir_path in key_dirs:
        expanded_path = os.path.expanduser(dir_path)
        diagnosis["file_status"][f"{dir_path}/"] = os.path.isdir(expanded_path)
    
    # 系統健康評分
    total_checks = len(key_files) + len(key_dirs)
    passed_checks = sum(diagnosis["file_status"].values())
    health_score = (passed_checks / total_checks) * 100
    
    diagnosis["system_info"] = {
        "health_score": f"{health_score:.1f}%",
        "api_completion": "79%",  # 基於您的統計
        "rtos_completion": "100%",
        "hal_completion": "82%"
    }
    
    return diagnosis


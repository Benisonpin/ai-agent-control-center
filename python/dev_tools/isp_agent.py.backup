@app.get("/")
def home():
    return {
        "message": "ISP AI Agent is running",
        "modules": ["dpc", "hdr", "demosaic", "awb", "ccm"],
        "features": ["generate", "optimize", "testbench"]
    }

@app.post("/generate/module")
async def generate_module(request: ISPModuleRequest):
    """生成 ISP 模組"""
    prompt = f"""Generate Verilog code for ISP {request.module_type} module.
Parameters: {json.dumps(request.parameters, indent=2)}
Bit width: {request.bit_width}

Requirements:
1. Complete synthesizable Verilog
2. Proper reset and clock handling
3. Parameterized design
4. Pipeline stages if needed
5. Clear comments

Generate the module:"""

    try:
        response = requests.post(
            "http://localhost:11434/api/generate",
            json={
                "model": "tinyllama",
                "prompt": prompt,
                "stream": False
            },
            timeout=120
        )
        
        if response.status_code == 200:
            result = response.json()
            return {
                "module_type": request.module_type,
                "parameters": request.parameters,
                "verilog_code": result.get("response", "")
            }
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))

@app.post("/optimize")
async def optimize_code(request: OptimizeRequest):
    """優化 Verilog 代碼"""
    prompt = f"""Optimize this Verilog code for {request.optimization_type}:

{request.verilog_code}

Provide optimized version with improvements."""

    try:
        response = requests.post(
            "http://localhost:11434/api/generate",
            json={"model": "tinyllama", "prompt": prompt, "stream": False},
            timeout=120
        )
        
        if response.status_code == 200:
            result = response.json()
            return {
                "optimization_type": request.optimization_type,
                "optimized_code": result.get("response", "")
            }
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))

@app.post("/generate/testbench")
async def generate_testbench(request: TestbenchRequest):
    """生成測試平台"""
    prompt = f"""Generate testbench for module {request.module_name}:

{request.module_code}

Include test vectors and automatic checking."""

    try:
        response = requests.post(
            "http://localhost:11434/api/generate",
            json={"model": "tinyllama", "prompt": prompt, "stream": False},
            timeout=120
        )
        
        if response.status_code == 200:
            result = response.json()
            return {
                "module_name": request.module_name,
                "testbench_code": result.get("response", "")
            }
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))


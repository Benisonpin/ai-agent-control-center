<script>
function proceedWithEnhancedCloudShell() {
    // 移除模態視窗
    document.querySelector('div[style*="position: fixed"]').remove();
    
    // 顯示保護啟動過程
    showNotification('🛡️ 啟動增強保護系統...');
    
    setTimeout(() => {
        showNotification('✅ 持續監控已啟動');
    }, 1000);
    
    setTimeout(() => {
        showNotification('📂 多重備份已建立');
    }, 2000);
    
    setTimeout(() => {
        showNotification('🚀 安全啟動 Cloud Shell...');
        
        // 記錄啟動時間和保護狀態
        localStorage.setItem('cteVibeProtectionActive', 'true');
        localStorage.setItem('cteVibeProtectionStart', Date.now());
        
        // 開啟 Cloud Shell
        window.open('https://shell.cloud.google.com/?cloudshell_git_repo=https://github.com/Benisonpin/ai-agent-control-center.git&cloudshell_tutorial=README.md&cloudshell_workspace=.', '_blank');
        
    }, 3000);
    
    // 啟動定期提醒
    setInterval(() => {
        if (localStorage.getItem('cteVibeProtectionActive') === 'true') {
            showNotification('💡 提醒：檔案持續保護中，如需恢復執行 ~/INSTANT_RECOVERY.sh');
        }
    }, 300000); // 每5分鐘提醒一次
}

function cancelEnhancedCloudShell() {
    document.querySelector('div[style*="position: fixed"]').remove();
    showNotification('❌ Cloud Shell 啟動已取消');
}

// 檢查保護狀態
function checkProtectionStatus() {
    if (localStorage.getItem('cteVibeProtectionActive') === 'true') {
        const startTime = localStorage.getItem('cteVibeProtectionStart');
        const elapsed = Date.now() - parseInt(startTime);
        const minutes = Math.floor(elapsed / 60000);
        
        if (minutes > 2) {
            showNotification(`⚡ 保護系統運行 ${minutes} 分鐘，隨時可執行恢復指令`);
        }
    }
}

// 頁面載入時檢查保護狀態
window.addEventListener('load', () => {
    setTimeout(checkProtectionStatus, 3000);
});

</script>

<script>
// AI 模型開發功能
function startAITraining() {
    showNotification('🧠 啟動 AI 模型訓練管線...', 'info');
    
    // 模擬訓練過程
    const trainingSteps = [
        '📊 智能資料收集中...',
        '🎯 AI 輔助標註進行中...',
        '🧠 多模型並行訓練...',
        '🔬 知識蒸餾優化中...',
        '✅ AI 模型訓練完成！'
    ];
    
    trainingSteps.forEach((step, index) => {
        setTimeout(() => {
            showNotification(step, index === trainingSteps.length - 1 ? 'success' : 'info');
        }, (index + 1) * 2000);
    });
}

function deployToFPGA() {

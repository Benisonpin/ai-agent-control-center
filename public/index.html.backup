                    </div>
                </div>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-top: 2rem;">
                <button class="btn btn-primary" onclick="deployToNetlify()">
                    <i class="fas fa-rocket"></i> 部署
                <button class="btn btn-primary" onclick="startAITraining()" style="width: 100%; margin-top: 1rem;">
                    <i class="fas fa-brain mr-2"></i>啟動 AI 訓練

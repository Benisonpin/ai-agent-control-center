        <!-- AI 功能 -->
        <div class="panel">
            <h3 style="color: #60A5FA; margin-bottom: 1.5rem;">
                <i class="fas fa-brain"></i> AI 協作功能
            </h3>
            
            <div style="display: grid; gap: 1rem;">
                <div style="display: flex; align-items: center; padding: 1rem; background: rgba(139, 92, 246, 0.1); border-radius: 8px; border-left: 4px solid #8B5CF6;">
                    <i class="fas fa-magic" style="margin-right: 0.75rem; color: #A78BFA;"></i>
                    <div>
                        <div style="font-weight: 600;">智能程式碼生成</div>
                        <div style="font-size: 0.875rem; color: #94A3B8;">AI 輔助開發</div>
                    </div>
                </div>
                <div style="display: flex; align-items: center; padding: 1rem; background: rgba(139, 92, 246, 0.1); border-radius: 8px; border-left: 4px solid #8B5CF6;">
                    <i class="fas fa-eye" style="margin-right: 0.75rem; color: #A78BFA;"></i>
                    <div>
                        <div style="font-weight: 600;">無人機影像處理</div>
                <div style="display: flex; align-items: center; padding: 1rem; background: rgba(139, 92, 246, 0.1); border-radius: 8px; border-left: 4px solid #8B5CF6; margin-top: 0.5rem;">
                    <i class="fas fa-graduation-cap" style="margin-right: 0.75rem; color: #A78BFA;"></i>
                    <div>
                        <div style="font-weight: 600;">AI 模型訓練</div>
                        <div style="font-size: 0.875rem; color: #94A3B8;">自動收集→訓練→蒸餾→部署</div>
                <button class="btn btn-primary" onclick="startAITraining()" style="width: 100%; margin-top: 1rem;">
                    <i class="fas fa-brain mr-2"></i>啟動 AI 訓練
                </button>
                <button class="btn btn-secondary" onclick="deployToFPGA()" style="width: 100%; margin-top: 0.5rem;">
                    <i class="fas fa-microchip mr-2"></i>部署到 FPGA
                <button class="btn btn-warning" onclick="runFPGADevelopment()" style="width: 100%; margin-top: 0.5rem;">
                    <i class="fas fa-tools mr-2"></i>FPGA 開發流程
                </button>
                <button class="btn btn-info" onclick="generateTestbench()" style="width: 100%; margin-top: 0.5rem;">
                    <i class="fas fa-vial mr-2"></i>生成 Testbench
                </button>
                </button>
                    </div>
                </div>
                <div style="display: flex; align-items: center; padding: 1rem; background: rgba(16, 185, 129, 0.1); border-radius: 8px; border-left: 4px solid #10B981; margin-top: 0.5rem;">
                    <i class="fas fa-microchip" style="margin-right: 0.75rem; color: #34D399;"></i>
                    <div>
                        <div style="font-weight: 600;">FPGA 硬體加速</div>
                        <div style="font-size: 0.875rem; color: #94A3B8;">即時推理 + OTA 更新</div>
                    </div>
                </div>
                <div style="display: flex; align-items: center; padding: 1rem; background: rgba(239, 68, 68, 0.1); border-radius: 8px; border-left: 4px solid #EF4444; margin-top: 0.5rem;">
                    <i class="fas fa-cogs" style="margin-right: 0.75rem; color: #F87171;"></i>
                    <div>
                        <div style="font-weight: 600;">FreeRTOS 多工系統</div>
                <div style="display: flex; align-items: center; padding: 1rem; background: rgba(245, 158, 11, 0.1); border-radius: 8px; border-left: 4px solid #F59E0B; margin-top: 0.5rem;">
                    <i class="fas fa-microchip" style="margin-right: 0.75rem; color: #FBBF24;"></i>
                    <div>
                        <div style="font-weight: 600;">Lattice FPGA 整合</div>
                        <div style="font-size: 0.875rem; color: #94A3B8;">LIFCL-40 + Radiant + ModelSim</div>
                    </div>
                </div>
                        <div style="font-size: 0.875rem; color: #94A3B8;">32.5fps 即時任務排程</div>
                    </div>
                </div>
                <div style="display: flex; align-items: center; padding: 1rem; background: rgba(239, 68, 68, 0.1); border-radius: 8px; border-left: 4px solid #EF4444; margin-top: 0.5rem;">
                    <i class="fas fa-cogs" style="margin-right: 0.75rem; color: #F87171;"></i>
                    <div>

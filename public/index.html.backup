<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CTE Vibe Code for AI Image Drone Chip</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/tailwindcss/2.2.19/tailwind.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'SF Pro Display', -apple-system, BlinkMacSystemFont, sans-serif;
            background: linear-gradient(135deg, #0F172A 0%, #1E293B 100%);
            color: #F1F5F9;
            height: 100vh;
            overflow: hidden;
        }

        .header {
            background: linear-gradient(90deg, #3B82F6 0%, #8B5CF6 100%);
            padding: 1rem 2rem;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 4px 20px rgba(59, 130, 246, 0.3);
        }

        .header h1 {
            font-size: 2rem;
            font-weight: 700;
            color: white;
            text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
        }

        .subtitle {
            font-size: 1rem;
            color: rgba(255, 255, 255, 0.9);
            margin-left: 1rem;
        }

        .main-container {
            display: grid;
            grid-template-columns: 1fr 1fr 1fr;
            gap: 2rem;
            padding: 2rem;
            height: calc(100vh - 120px);
        }

        .panel {
            background: rgba(30, 41, 59, 0.9);
            border: 1px solid rgba(59, 130, 246, 0.3);
            border-radius: 16px;
            padding: 2rem;
            backdrop-filter: blur(10px);
            transition: all 0.3s ease;
        }

        .panel:hover {
            border-color: rgba(59, 130, 246, 0.6);
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(59, 130, 246, 0.2);
        }

        .panel-title {
            display: flex;
            align-items: center;
            font-size: 1.5rem;
            font-weight: 600;
            margin-bottom: 1.5rem;
            color: #60A5FA;
        }

        .panel-title i {
            margin-right: 0.75rem;
            font-size: 1.75rem;
        }

        .status-grid {
            display: grid;
            gap: 1rem;
        }

        .status-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0.75rem 1rem;
            background: rgba(15, 23, 42, 0.8);
            border-radius: 8px;
            border-left: 4px solid #10B981;
        }

        .status-label {
            font-weight: 500;
            color: #CBD5E1;
        }

        .status-value {
            font-weight: 600;
            color: #10B981;
        }

        .file-tree {
            max-height: 400px;
            overflow-y: auto;
        }

        .file-item {
            display: flex;
            align-items: center;
            padding: 0.75rem;
            margin: 0.25rem 0;
            background: rgba(15, 23, 42, 0.6);
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.2s ease;
        }

        .file-item:hover {
            background: rgba(59, 130, 246, 0.2);
            transform: translateX(4px);
        }

        .file-icon {
            margin-right: 0.75rem;
            font-size: 1.25rem;
        }

        .git-buttons {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
            margin-top: 1.5rem;
        }

        .btn {
            padding: 0.75rem 1.5rem;
            border: none;
            border-radius: 8px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
        }

        .btn-primary {
            background: linear-gradient(135deg, #3B82F6 0%, #1D4ED8 100%);
            color: white;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 15px rgba(59, 130, 246, 0.4);
        }

        .btn-secondary {
            background: linear-gradient(135deg, #10B981 0%, #059669 100%);
            color: white;
        }

        .btn-secondary:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 15px rgba(16, 185, 129, 0.4);
        }

        .performance-metrics {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
            margin-top: 1rem;
        }

        .metric-card {
            background: linear-gradient(135deg, rgba(59, 130, 246, 0.1) 0%, rgba(139, 92, 246, 0.1) 100%);
            padding: 1rem;
            border-radius: 12px;
            text-align: center;
            border: 1px solid rgba(59, 130, 246, 0.2);
        }

        .metric-value {
            font-size: 1.5rem;
            font-weight: 700;
            color: #60A5FA;
        }

        .metric-label {
            font-size: 0.875rem;
            color: #94A3B8;
            margin-top: 0.25rem;
        }

        .ai-features {
            display: grid;
            gap: 1rem;
            margin-top: 1rem;
        }

        .ai-feature {
            display: flex;
            align-items: center;
            padding: 1rem;
            background: rgba(139, 92, 246, 0.1);
            border-radius: 8px;
            border-left: 4px solid #8B5CF6;
        }

        .ai-feature i {
            margin-right: 0.75rem;
            color: #A78BFA;
            font-size: 1.25rem;
        }

        .animated-bg {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: -1;
            opacity: 0.1;
        }

        .floating-particle {
            position: absolute;
            background: radial-gradient(circle, #60A5FA, transparent);
            border-radius: 50%;
            animation: float 6s ease-in-out infinite;
        }

        @keyframes float {
            0%, 100% { transform: translateY(0px) rotate(0deg); }
            50% { transform: translateY(-20px) rotate(180deg); }
        }

        .deployment-status {
            position: fixed;
            bottom: 20px;
            right: 20px;
            background: rgba(16, 185, 129, 0.9);
            color: white;
            padding: 1rem 1.5rem;
            border-radius: 12px;
            font-weight: 600;
            box-shadow: 0 4px 20px rgba(16, 185, 129, 0.3);
            animation: slideIn 0.5s ease;
        }

        @keyframes slideIn {
            from { transform: translateX(100%); opacity: 0; }
            to { transform: translateX(0); opacity: 1; }
        }
    </style>
</head>
<body>
    <!-- 動態背景 -->
    <div class="animated-bg" id="animatedBg"></div>

    <!-- 頂部標題 -->
    <div class="header">
        <div>
            <h1><i class="fas fa-robot"></i> CTE Vibe Code for AI Image Drone Chip</h1>
            <div class="subtitle">AI-Powered Image Processing for Drone Applications | 4K@32.5fps | 28ms latency | 3.5W efficiency</div>
        </div>
    </div>

    <!-- 主要內容 -->
    <div class="main-container">
        <!-- 連接狀態面板 -->
        <div class="panel">
            <div class="panel-title">
                <i class="fas fa-cloud"></i>
                系統狀態監控
            </div>
            
            <div class="status-grid">
                <div class="status-item">
                    <span class="status-label">Cloud Shell 狀態</span>
                    <span class="status-value">✅ 已連接</span>
                </div>
                <div class="status-item">
                    <span class="status-label">專案 ID</span>
                    <span class="status-value">TW-LCEO-AISP-2025</span>
                </div>
                <div class="status-item">
                    <span class="status-label">區域</span>
                    <span class="status-value">asia-east1</span>
                </div>
                <div class="status-item">
                    <span class="status-label">檔案保護</span>
                    <span class="status-value">🛡️ 啟動</span>
                </div>
            </div>

            <div class="performance-metrics">
                <div class="metric-card">
                    <div class="metric-value">32.5</div>
                    <div class="metric-label">FPS</div>
                </div>
                <div class="metric-card">
                    <div class="metric-value">28ms</div>
                    <div class="metric-label">延遲</div>
                </div>
                <div class="metric-card">
                    <div class="metric-value">3.5W</div>
                    <div class="metric-label">功耗</div>
                </div>
                <div class="metric-card">
                    <div class="metric-value">95%</div>
                    <div class="metric-label">AI準確度</div>
                </div>
            </div>

            <div class="git-buttons">
                <button class="btn btn-primary" onclick="openSmartCloudShell()">
                    <i class="fas fa-terminal"></i>
                    智能 Cloud Shell
                </button>
                <button class="btn btn-secondary" onclick="openAIIDE()">
                    <i class="fas fa-code"></i>
                    AI 協作 IDE
                </button>
            </div>
        </div>

        <!-- 專案檔案結構 -->
        <div class="panel">
            <div class="panel-title">
                <i class="fas fa-folder-tree"></i>
                專案檔案架構
            </div>
            
            <div class="file-tree">
                <div class="file-item" onclick="openFile('rtl/ai_agent_core.v')">
                    <i class="fas fa-microchip file-icon" style="color: #A78BFA;"></i>
                    <span>rtl/ai_agent_core.v</span>
                </div>
                <div class="file-item" onclick="openFile('rtl/ai_accelerator_top.v')">
                    <i class="fas fa-bolt file-icon" style="color: #FBBF24;"></i>
                    <span>rtl/ai_accelerator_top.v</span>
                </div>
                <div class="file-item" onclick="openFile('rtl/demosaic.v')">
                    <i class="fas fa-image file-icon" style="color: #10B981;"></i>
                    <span>rtl/demosaic.v</span>
                </div>
                <div class="file-item" onclick="openFile('rtl/hdr_module.v')">
                    <i class="fas fa-adjust file-icon" style="color: #F59E0B;"></i>
                    <span>rtl/hdr_module.v</span>
                </div>
                <div class="file-item" onclick="openFile('python/working_agent.py')">
                    <i class="fab fa-python file-icon" style="color: #3B82F6;"></i>
                    <span>python/working_agent.py</span>
                </div>
                <div class="file-item" onclick="openFile('python/smart_agent.sh')">
                    <i class="fas fa-terminal file-icon" style="color: #10B981;"></i>
                    <span>python/smart_agent.sh</span>
                </div>
                <div class="file-item" onclick="openFile('python/analyze_vcd.py')">
                    <i class="fas fa-chart-line file-icon" style="color: #8B5CF6;"></i>
                    <span>python/analyze_vcd.py</span>
                </div>
                <div class="file-item" onclick="openFile('integrated/isp_pipeline_ai.v')">
                    <i class="fas fa-sitemap file-icon" style="color: #06B6D4;"></i>
                    <span>integrated/isp_pipeline_ai.v</span>
                </div>
            </div>
        </div>

        <!-- AI 功能面板 -->
        <div class="panel">
            <div class="panel-title">
                <i class="fas fa-brain"></i>
                AI 協作功能
            </div>
            
            <div class="ai-features">
                <div class="ai-feature">
                    <i class="fas fa-magic"></i>
                    <div>
                        <div style="font-weight: 600;">智能程式碼生成</div>
                        <div style="font-size: 0.875rem; color: #94A3B8;">自然語言轉 RTL/Python 程式碼</div>
                    </div>
                </div>
                <div class="ai-feature">
                    <i class="fas fa-tachometer-alt"></i>
                    <div>
                        <div style="font-weight: 600;">效能優化分析</div>
                        <div style="font-size: 0.875rem; color: #94A3B8;">時序分析與功耗優化建議</div>
                    </div>
                </div>
                <div class="ai-feature">
                    <i class="fas fa-bug"></i>
                    <div>
                        <div style="font-weight: 600;">智能除錯助手</div>
                        <div style="font-size: 0.875rem; color: #94A3B8;">自動錯誤檢測與修復建議</div>
                    </div>
                </div>
                <div class="ai-feature">
                    <i class="fas fa-eye"></i>
                    <div>
                        <div style="font-weight: 600;">13種場景辨識</div>
                        <div style="font-size: 0.875rem; color: #94A3B8;">室內外、夜景、運動等場景 AI</div>
                    </div>
                </div>
                <div class="ai-feature">
                    <i class="fas fa-crosshairs"></i>
                    <div>
                        <div style="font-weight: 600;">即時物件追蹤</div>
                        <div style="font-size: 0.875rem; color: #94A3B8;">人物、車輛等多目標追蹤</div>
                    </div>
                </div>
            </div>

            <div class="git-buttons" style="margin-top: 2rem;">
                <button class="btn btn-primary" onclick="deployToNetlify()">
                    <i class="fas fa-rocket"></i>
                    立即部署
                </button>
                <button class="btn btn-secondary" onclick="openGitHub()">
                    <i class="fab fa-github"></i>
                    GitHub 同步
                </button>
            </div>
        </div>
    </div>

    <!-- 部署狀態通知 -->
    <div class="deployment-status">
        <i class="fas fa-check-circle"></i>
        TW-LCEO-AISP-2025 AI 平台已就緒！
    </div>

    <script>
        // 建立動態背景粒子
        function createFloatingParticles() {
            const bg = document.getElementById('animatedBg');
            for (let i = 0; i < 20; i++) {
                const particle = document.createElement('div');
                particle.className = 'floating-particle';
                particle.style.width = Math.random() * 6 + 2 + 'px';
                particle.style.height = particle.style.width;
                particle.style.left = Math.random() * 100 + '%';
                particle.style.top = Math.random() * 100 + '%';
                particle.style.animationDelay = Math.random() * 6 + 's';
                bg.appendChild(particle);
            }
        }

        // 智能 Cloud Shell（無 --force_new_clone）
        function openSmartCloudShell() {
            const url = 'https://shell.cloud.google.com/?cloudshell_git_repo=https://github.com/Benisonpin/ai-agent-control-center.git&cloudshell_tutorial=README.md&cloudshell_workspace=.';
            window.open(url, '_blank');
            showNotification('🚀 智能 Cloud Shell 已啟動（檔案保護模式）');
        }

        // AI 協作 IDE
        function openAIIDE() {
            // 這裡可以整合完整的 Monaco Editor IDE
            showNotification('💻 AI 協作 IDE 啟動中...');
            // 實際實現時會載入完整的編輯器介面
        }

        // 檔案操作
        function openFile(fileName) {
            showNotification(`📝 開啟檔案: ${fileName}`);
            // 這裡會實際載入和顯示檔案內容
        }

        // GitHub 同步
        function openGitHub() {
            window.open('https://github.com/Benisonpin/ai-agent-control-center', '_blank');
            showNotification('🔗 GitHub 儲存庫已開啟');
        }

        // Netlify 部署
        function deployToNetlify() {
            showNotification('🚀 正在部署到 Netlify...');
            setTimeout(() => {
                showNotification('✅ 部署完成！平台已更新');
            }, 3000);
        }

        // 通知功能
        function showNotification(message) {
            const notification = document.createElement('div');
            notification.style.cssText = `
                position: fixed;
                top: 20px;
                right: 20px;
                background: rgba(59, 130, 246, 0.9);
                color: white;
                padding: 1rem 1.5rem;
                border-radius: 8px;
                font-weight: 600;
                z-index: 1000;
                animation: slideIn 0.3s ease;
            `;
            notification.textContent = message;
            document.body.appendChild(notification);
            
            setTimeout(() => {
                notification.remove();
            }, 3000);
        }

        // 頁面載入完成後執行
        window.addEventListener('load', () => {
            createFloatingParticles();
            
            // 顯示歡迎訊息
            setTimeout(() => {
                showNotification('🎉 歡迎使用 TW-LCEO-AISP-2025 AI 協作平台！');
            }, 1000);
        });

        // 即時更新效能指標
        setInterval(() => {
            const metrics = document.querySelectorAll('.metric-value');
            // 模擬即時數據更新
            // 實際使用時會從後端 API 獲取真實數據
        }, 5000);
    </script>
</body>
</html>

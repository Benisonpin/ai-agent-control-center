                <div class="file-item" onclick="openFile('lattice_fpga/rtl/cte_vibe_top.v')">
                    <i class="fas fa-microchip" style="margin-right: 0.75rem; color: #F59E0B;"></i>
                    <span>lattice_fpga/rtl/cte_vibe_top.v</span>
                </div>
                <div class="file-item" onclick="openFile('lattice_fpga/constraints/cte_vibe_pins.pdc')">
                    <i class="fas fa-map-pin" style="margin-right: 0.75rem; color: #10B981;"></i>
                    <span>lattice_fpga/constraints/cte_vibe_pins.pdc</span>
                </div>
                <div class="file-item" onclick="openFile('testbench/generated/tb_cte_vibe_top.v')">

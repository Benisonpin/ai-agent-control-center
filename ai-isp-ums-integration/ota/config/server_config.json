{
  "servers": {
    "primary": {
      "url": "https://ota.yourdomain.com",
      "region": "asia-pacific",
      "cdn": true
    },
    "backup": {
      "url": "https://backup-ota.yourdomain.com",
      "region": "us-west",
      "cdn": false
    },
    "local": {
      "url": "http://192.168.1.100:8080",
      "region": "local",
      "cdn": false,
      "use_for": "testing"
    }
  },
  "network": {
    "retry_attempts": 3,
    "timeout_seconds": 30,
    "bandwidth_limit_mbps": 10,
    "prefer_wifi": true,
    "allow_cellular": false
  }
}
